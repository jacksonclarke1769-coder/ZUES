# Copy this file to `.env` (which is gitignored) and fill in your real values.
# The bot auto-loads .env at launch via env_loader.py. Shell-exported vars override these.

# TradersPost webhook for your Apex 50K (Strategy -> Webhook -> copy the full URL).
# The URL embeds your unique token, so this IS the key. Single-account live runs use this one:
TRADERSPOST_LIVE_URL=https://webhooks.traderspost.io/trading/webhook/YOUR-UUID/YOUR-TOKEN

# Optional: per-account override for a fan-out / backup account (only if you run extra lanes):
# TRADERSPOST_APEX_URL=https://webhooks.traderspost.io/trading/webhook/.../...

# Tradovate READ credentials — ONLY for firms that permit API access (Apex bans API keys during
# evals/funded: leave these EMPTY on Apex; read-back uses the TradingView panel instead).
# TRADOVATE_ENV=demo
# TRADOVATE_USER=your-username
# TRADOVATE_PASS=your-password
# TRADOVATE_CID=your-api-cid
# TRADOVATE_SEC=your-api-secret
# TRADOVATE_ACCOUNT_SPEC=your-account-name

# Quarterly roll-week override: pin MNQ orders to the active front-month contract.
# Required during the ~10-day window before the 3rd-Friday expiry of Mar/Jun/Sep/Dec.
# Without this, TradingView (NQ1!) and TradersPost/Tradovate may resolve DIFFERENT contracts,
# shifting bracket prices by 75-150 pts. The preflight will BLOCK if this is unset in-window.
# TP_SYMBOL_MNQ=MNQU2026  # pin during quarterly roll weeks
