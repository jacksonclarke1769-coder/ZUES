# Copy this file to `.env` (which is gitignored) and fill in your real values.
# The bot auto-loads .env at launch via env_loader.py. Shell-exported vars override these.

# TradersPost webhook for your Apex 50K (Strategy -> Webhook -> copy the full URL).
# The URL embeds your unique token, so this IS the key. Single-account live runs use this one:
TRADERSPOST_LIVE_URL=https://webhooks.traderspost.io/trading/webhook/YOUR-UUID/YOUR-TOKEN

# Optional: per-account override for a fan-out / backup account (only if you run extra lanes):
# TRADERSPOST_APEX_URL=https://webhooks.traderspost.io/trading/webhook/.../...
